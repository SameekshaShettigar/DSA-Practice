
class Solution {
public:
    int minDays(int n) {
        vector<int> dp(n+1,0);
        
        dp[0]=0;
        dp[1]=1;
        for(int i = 2 ; i<=n ; i++){
            dp[i] = dp[i-1]+1;
            if(i%2 == 0){
                dp[i] = min(dp[i],1+dp[i/2]);
            }
            if(i%3 == 0){
                dp[i] = min(dp[i],1+dp[i/3]);
            }
        }
        return dp[n];
        
    }
};

TC:O(n)
SC: O(n)
